# 推奨: フロントのみローカル、バックエンドは AWS ECS ALB
# npm run dev / pnpm dev 時、Vite が /api と /ws をこの URL へプロキシする
VITE_DEV_BACKEND_URL=http://syodan-alb-520683133.ap-northeast-1.elb.amazonaws.com

# 手元で backend を起動する場合のみ（docker compose + uvicorn :8000）
# VITE_DEV_BACKEND_URL=http://127.0.0.1:8000

# 本番ビルド時（Cloudflare Pages 等）
# VITE_API_BASE_URL=
# VITE_WS_BASE_URL=

# Slack トークンはフロントではなく backend/.env に設定してください