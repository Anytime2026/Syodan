# ローカル backend 開発時
# VITE_DEV_BACKEND_URL=

# フロントのみローカル・backend は AWS ECS のとき（推奨）
VITE_DEV_BACKEND_URL=
# VITE_WS_BASE_URL は未設定時 VITE_API_BASE_URL から自動導出 (http→ws, https→wss)

# AWS ALB 接続時（フロントは localhost:5173、バックエンドは AWS）
# VITE_API_BASE_URL=
# VITE_WS_BASE_URL は省略可（上記から wss:// が自動導出される）

# Cloudflare Pages 本番デプロイ時は VITE_API_BASE_URL / VITE_WS_BASE_URL を空のまま
# Pages Functions が同一オリジンで ALB へプロキシする
# 本番ビルドは .env.production が .env の ALB URL を上書きする
