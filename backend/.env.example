# Application
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (local docker-compose)
DATABASE_URL=

# AWS
AWS_REGION=ap-northeast-1
AWS_STUB_MODE=true
S3_BUCKET_NAME=
S3_ENDPOINT_URL=

# Bedrock inference profile IDs (invoke via ap-northeast-1)
BEDROCK_CHAT_MODEL_ID=jp.anthropic.claude-sonnet-4-6
BEDROCK_ANALYSIS_MODEL_ID=jp.anthropic.claude-sonnet-4-6

# Polly
POLLY_VOICE_ID=
POLLY_ENGINE=
POLLY_SPEECH_RATE=110%

# Secrets (local dev only — use Secrets Manager on ECS)
INTERNAL_API_KEY=
HULFT_WEBHOOK_URL=
HULFT_STUB_MODE=

# Session
SESSION_TIME_WARNING_SEC=120

# HULFTSquare
HULFT_EMAIL=
HULFT_PASSWORD=
HULFT_REFRESH_TOKEN=

