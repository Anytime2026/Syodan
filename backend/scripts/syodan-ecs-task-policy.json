{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockClaudeInvoke",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": [
        "arn:aws:bedrock:ap-northeast-1::foundation-model/anthropic.claude-*",
        "arn:aws:bedrock:ap-northeast-3::foundation-model/anthropic.claude-*",
        "arn:aws:bedrock:ap-northeast-1:542000445970:inference-profile/*",
        "arn:aws:bedrock:ap-northeast-3:542000445970:inference-profile/jp.anthropic.claude-sonnet-4-6"
      ]
    },
    {
      "Sid": "TranscribeJobs",
      "Effect": "Allow",
      "Action": [
        "transcribe:StartTranscriptionJob",
        "transcribe:GetTranscriptionJob"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PollyTTS",
      "Effect": "Allow",
      "Action": ["polly:SynthesizeSpeech"],
      "Resource": "*"
    },
    {
      "Sid": "S3AudioBucket",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject"],
      "Resource": "arn:aws:s3:::syodan-audio-542000445970-ap-northeast-1-an/*"
    }
  ]
}
